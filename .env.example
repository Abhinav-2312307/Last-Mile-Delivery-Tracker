# Database Connection (e.g. PostgreSQL, Neon)
DATABASE_URL="postgresql://username:password@hostname:5432/database_name?sslmode=require"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_key" # Can generate with `openssl rand -base64 32`

# Razorpay Payment Gateway (Test Mode credentials)
NEXT_PUBLIC_RAZORPAY_KEY_ID="your_razorpay_key_id"
razorpay_key_id="your_razorpay_key_id"
razorpay_key_secret="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# Google OAuth Credentials (for social login)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Gmail SMTP Credentials (for notification emails)
GMAIL_USER="your_gmail_address@gmail.com"
GMAIL_APP_PASSWORD="your_gmail_app_password" # Use App Passwords, not your primary password

# Security Secrets
EMAIL_VERIFICATION_SECRET="your_email_verification_secret_key"
